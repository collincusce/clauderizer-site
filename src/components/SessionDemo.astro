---
// SCENE 02 — "This is what momentum feels like": the SessionStart digest,
// played out in a terminal. This is the digest for this very site.
const phases = [
  { n: 0, name: 'Design system', done: true },
  { n: 1, name: 'Title sequence', done: true },
  { n: 2, name: 'Scene language', done: true },
  { n: 3, name: 'WebGL bloom', done: false, current: true },
  { n: 4, name: 'Proof + polish', done: false },
  { n: 5, name: 'Premiere', done: false },
];
---

<section class="section session" id="session">
  <div class="container">
    <p class="slug reveal reveal-sm"><span class="no">Scene 02</span> Int. fresh session - night</p>
    <h2 class="reveal">Your agent starts <em>oriented</em>, not blank.</h2>
    <p class="sub reveal">
      Before you type a word, the SessionStart hook has already told the agent exactly where things
      stand. No prescribed reading order, no re-briefing.
      <strong>This is the digest for this very site.</strong>
    </p>

    <div class="terminal reveal" data-term>
      <div class="term-bar">
        <span class="lights" aria-hidden="true"><i></i><i></i><i></i></span>
        <span class="term-title">coding agent · fresh session</span>
        <div class="term-controls">
          <button type="button" class="term-btn" data-term-toggle aria-label="Pause the demo">
            <span class="ico-pause" aria-hidden="true"></span><span data-toggle-label>Pause</span>
          </button>
          <button type="button" class="term-btn" data-term-replay aria-label="Replay the demo">
            ↺ Replay
          </button>
        </div>
      </div>

      <div class="term-body" aria-live="polite">
        <p class="ln ctx" data-line>you open a fresh session, nothing typed yet</p>

        <div class="digest" data-line>
          <span class="digest-bar" aria-hidden="true"></span>
          <p class="ln" data-type>
            <span class="t-ember">[Clauderizer]</span> gameplan <span class="t-cream"
              >directors-cut</span
            > · phase <span class="t-cream">3 / 6</span>
          </p>
          <p class="ln" data-type>
            <span class="t-mut">baseline</span> 0 tests <span class="t-mut">·</span>
            <span class="t-ember">10 lessons</span>
            <span class="t-mut">· 0 pending cascades</span>
          </p>
          <p class="ln" data-type>
            <span class="t-mut">next:</span>
            <span class="t-cream">cz_next_phase_context → cz_preflight</span>
          </p>
          <p class="ln note" data-line>
            ↑ injected automatically: no prescribed reading order, no re-briefing
          </p>
        </div>

        <p class="ln agent" data-line>
          <span class="caret-cursor">▸</span> I see where we are: phase 3 of 6. Preflight passed. Rolling
          the title sequence now.
        </p>

        <figure class="rail" data-line>
          <figcaption>phase 3 of 6 · this very site, built by dogfooding itself</figcaption>
          <ol class="rail-track" role="list">
            {
              phases.map((p) => (
                <li
                  class:list={['phase-node', { done: p.done, current: p.current }]}
                  data-node
                  data-done={p.done ? 'true' : 'false'}
                  aria-label={`Phase ${p.n}: ${p.name}${p.current ? ' (current)' : p.done ? ' (complete)' : ' (upcoming)'}`}
                >
                  <span class="node-dot" aria-hidden="true" />
                  <span class="node-n">{p.n}</span>
                </li>
              ))
            }
          </ol>
        </figure>

        <p class="ln punch" data-line>Every session picks up exactly where you left off.</p>
        <p class="ln tag" data-line>That&rsquo;s how you fly. ✦</p>
      </div>
    </div>
  </div>
</section>

<script>
  import { prefersReducedMotion, onNearViewport } from '@/lib/env';

  const term = document.querySelector<HTMLElement>('[data-term]');
  if (term) {
    const lines = [...term.querySelectorAll<HTMLElement>('[data-line]')];
    const nodes = [...term.querySelectorAll<HTMLElement>('[data-node]')];
    const toggleBtn = term.querySelector<HTMLButtonElement>('[data-term-toggle]');
    const replayBtn = term.querySelector<HTMLButtonElement>('[data-term-replay]');
    const toggleLabel = term.querySelector<HTMLElement>('[data-toggle-label]');

    const typed = [...term.querySelectorAll<HTMLElement>('[data-type]')].map((el) => ({
      el,
      text: el.textContent || '',
      source: [...el.childNodes].map((n) => n.cloneNode(true)),
    }));
    const restore = (t: (typeof typed)[number]) =>
      t.el.replaceChildren(...t.source.map((n) => n.cloneNode(true)));

    if (prefersReducedMotion()) {
      term.querySelector('.term-controls')?.setAttribute('hidden', '');
    } else {
      let tl: gsap.core.Timeline | null = null;
      let gsapRef: typeof import('gsap').gsap | null = null;

      const setStart = () => {
        lines.forEach((l) => {
          l.style.opacity = '0';
          l.style.transform = 'translateY(8px)';
        });
        nodes.forEach((n) => {
          n.classList.add('armed');
          n.style.opacity = '0.3';
        });
        typed.forEach((t) => {
          t.el.textContent = '';
        });
      };

      const build = (gsap: NonNullable<typeof gsapRef>) => {
        const t = gsap.timeline({ paused: true });
        lines.forEach((line) => {
          const ownTyped = typed.find((x) => x.el === line || line.contains(x.el));
          if (line.matches('.digest')) {
            t.to(line, { opacity: 1, y: 0, duration: 0.35, ease: 'power2.out' }, '>');
            typed
              .filter((x) => line.contains(x.el))
              .forEach((tw) => {
                const obj = { n: 0 };
                t.call(() => tw.el.classList.add('typing'), [], '>');
                t.to(
                  obj,
                  {
                    n: tw.text.length,
                    duration: Math.min(tw.text.length / 52, 1.6),
                    ease: 'none',
                    onUpdate: () => {
                      tw.el.textContent = tw.text.slice(0, Math.ceil(obj.n));
                    },
                    onComplete: () => {
                      tw.el.classList.remove('typing');
                      restore(tw);
                    },
                  },
                  '>',
                );
              });
          } else if (line.matches('.rail')) {
            t.to(line, { opacity: 1, y: 0, duration: 0.35 }, '>0.1');
            nodes.forEach((node, idx) => {
              t.to(
                node,
                {
                  opacity: 1,
                  duration: 0.28,
                  ease: 'power2.out',
                  onStart: () => node.classList.remove('armed'),
                },
                idx === 0 ? '>' : '>-0.16',
              );
            });
          } else if (!ownTyped) {
            t.to(line, { opacity: 1, y: 0, duration: 0.4, ease: 'power2.out' }, '>-0.05');
          }
        });
        t.eventCallback('onComplete', () => {
          if (toggleLabel) toggleLabel.textContent = 'Replay';
          term.classList.add('term-done');
        });
        return t;
      };

      const start = async () => {
        // Pin the measured height before any line is emptied for the typing
        // effect — the terminal, and the page below it, never reflows.
        const body = term.querySelector<HTMLElement>('.term-body');
        if (body) body.style.minHeight = `${body.offsetHeight}px`;
        const mod = await import('gsap');
        gsapRef = mod.gsap;
        setStart();
        tl = build(gsapRef);
        tl.play();
      };

      let started = false;
      onNearViewport(
        term,
        () => {
          if (started) return;
          started = true;
          start();
        },
        '-10% 0px',
      );

      toggleBtn?.addEventListener('click', () => {
        if (!tl) {
          start();
          return;
        }
        if (!tl.paused() && tl.progress() < 1) {
          tl.pause();
          if (toggleLabel) toggleLabel.textContent = 'Play';
          term.classList.add('term-paused');
        } else {
          if (tl.progress() === 1) tl.restart();
          else tl.play();
          if (toggleLabel) toggleLabel.textContent = 'Pause';
          term.classList.remove('term-paused');
        }
      });

      replayBtn?.addEventListener('click', () => {
        if (!gsapRef) {
          start();
          return;
        }
        setStart();
        tl = build(gsapRef);
        term.classList.remove('term-done', 'term-paused');
        if (toggleLabel) toggleLabel.textContent = 'Pause';
        tl.play();
      });
    }
  }
</script>

<style>
  .session {
    background: var(--ink-950);
  }
  .sub {
    margin: 0 0 2.2rem;
  }
  .sub strong {
    color: var(--ember-300);
    font-weight: 600;
  }

  .terminal {
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--edge);
    background: #06080b;
    box-shadow:
      0 50px 110px -55px rgba(0, 0, 0, 0.95),
      0 0 90px -40px var(--ember-glow),
      0 0 0 1px rgba(255, 255, 255, 0.02);
    max-width: 58rem;
  }
  .term-bar {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    padding: 0.75rem 1rem;
    background: linear-gradient(180deg, #12161d, #0b0e14);
    border-bottom: 1px solid var(--edge);
  }
  .lights {
    display: inline-flex;
    gap: 0.45rem;
  }
  .lights i {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    display: block;
  }
  .lights i:nth-child(1) {
    background: #e5685c;
  }
  .lights i:nth-child(2) {
    background: #e0a93f;
  }
  .lights i:nth-child(3) {
    background: #57c24a;
  }
  .term-title {
    font-family: var(--font-mono);
    font-size: 0.76rem;
    letter-spacing: 0.04em;
    color: var(--muted);
  }
  .term-controls {
    margin-left: auto;
    display: flex;
    gap: 0.5rem;
  }
  .term-controls[hidden] {
    display: none;
  }
  .term-btn {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--cream-200);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--edge);
    border-radius: 7px;
    padding: 0.28rem 0.6rem;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    transition:
      border-color 0.15s ease,
      color 0.15s ease,
      background 0.15s ease;
  }
  .term-btn:hover {
    border-color: var(--ember-500);
    color: var(--ember-300);
  }
  .term-btn:focus-visible {
    outline: 2px solid var(--ember-500);
    outline-offset: 2px;
  }
  .ico-pause {
    width: 8px;
    height: 9px;
    border-left: 2.5px solid currentColor;
    border-right: 2.5px solid currentColor;
  }
  .term-paused .ico-pause {
    width: 0;
    height: 0;
    border-left: 7px solid currentColor;
    border-right: 0;
    border-top: 5px solid transparent;
    border-bottom: 5px solid transparent;
  }

  .term-body {
    padding: 1.15rem 1.4rem 1.3rem;
    font-family: var(--font-mono);
    font-size: 0.86rem;
    line-height: 1.72;
    color: var(--cream-200);
    min-height: 280px;
  }
  .ln {
    margin: 0;
  }
  .ctx {
    color: var(--muted);
    font-style: italic;
    margin-bottom: 0.9rem;
  }
  .digest {
    position: relative;
    background: rgba(245, 158, 11, 0.05);
    border: 1px solid rgba(255, 180, 84, 0.22);
    border-radius: 8px;
    padding: 0.9rem 1rem 0.95rem 1.15rem;
    margin-bottom: 1rem;
  }
  .digest-bar {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    border-radius: 2px;
    background: var(--ember-500);
    box-shadow: 0 0 12px var(--ember-glow);
  }
  .t-ember {
    color: var(--ember-400);
    font-weight: 600;
  }
  .t-cream {
    color: var(--cream-50);
    font-weight: 600;
  }
  .t-mut {
    color: var(--muted);
  }
  .note {
    color: var(--dim);
    font-style: italic;
    margin-top: 0.35rem;
  }
  .agent {
    margin-bottom: 1.1rem;
    color: var(--cream-50);
  }
  .agent .caret-cursor {
    color: var(--ember-400);
    font-weight: 700;
  }

  .typing::after {
    content: '';
    display: inline-block;
    width: 0.55em;
    height: 1.05em;
    transform: translateY(0.18em);
    margin-left: 1px;
    background: var(--ember-400);
    animation: term-caret 0.9s steps(1) infinite;
  }
  @keyframes term-caret {
    50% {
      opacity: 0;
    }
  }

  .rail {
    margin: 0 0 1.1rem;
    padding: 0.9rem 0 0.2rem;
  }
  .rail figcaption {
    color: var(--muted);
    font-size: 0.76rem;
    margin-bottom: 0.85rem;
  }
  .rail-track {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 0.55rem;
    flex-wrap: wrap;
  }
  .phase-node {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
  }
  .node-dot {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    border: 1.5px solid #232b38;
    background: #0d1117;
    display: grid;
    place-items: center;
    transition:
      background 0.3s ease,
      border-color 0.3s ease,
      box-shadow 0.3s ease;
  }
  .node-n {
    font-size: 0.68rem;
    color: var(--muted);
  }
  .phase-node.done:not(.armed) .node-dot {
    background: var(--ok);
    border-color: var(--ok);
    box-shadow: 0 0 0 4px var(--ok-soft);
  }
  .phase-node.done:not(.armed) .node-dot::after {
    content: '✓';
    color: #07210a;
    font-size: 0.72rem;
    font-weight: 700;
  }
  .phase-node.current:not(.armed) .node-dot {
    border-color: var(--ember-500);
    background: var(--ember-soft);
    box-shadow: 0 0 0 4px var(--ember-soft);
    animation: node-pulse 2s ease-in-out infinite;
  }
  .phase-node.current:not(.armed) .node-n {
    color: var(--ember-300);
  }
  @keyframes node-pulse {
    0%,
    100% {
      box-shadow: 0 0 0 4px var(--ember-soft);
    }
    50% {
      box-shadow: 0 0 0 8px rgba(245, 158, 11, 0.07);
    }
  }

  .punch {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 480;
    font-size: clamp(1.3rem, 2.6vw, 1.75rem);
    letter-spacing: -0.01em;
    color: var(--cream-50);
    margin-top: 0.5rem;
  }
  .tag {
    color: var(--ember-400);
    margin-top: 0.25rem;
    font-size: 0.92rem;
  }

  @media (max-width: 560px) {
    .term-body {
      font-size: 0.78rem;
    }
    .node-dot {
      width: 19px;
      height: 19px;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .phase-node.current .node-dot {
      animation: none;
    }
  }
</style>
