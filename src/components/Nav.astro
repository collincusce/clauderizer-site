---
const links = [
  { href: '#how-it-works', label: 'How it works' },
  { href: '#features', label: 'Features' },
  { href: '#quickstart', label: 'Quickstart' },
  { href: '#faq', label: 'FAQ' },
];
---

<header class="nav" id="top" data-nav>
  <div class="nav-inner container">
    <a class="brand" href="#top" aria-label="Clauderizer home">
      <svg class="mark" viewBox="0 0 32 32" aria-hidden="true">
        <circle cx="16" cy="16" r="8.5" fill="none" stroke="var(--ember-500)" stroke-width="2.4"
        ></circle>
        <circle cx="16" cy="16" r="2.6" fill="var(--ember-300)"></circle>
        <circle
          cx="16"
          cy="16"
          r="13.5"
          fill="none"
          stroke="var(--ember-line)"
          stroke-width="1"
          stroke-dasharray="2 5"></circle>
      </svg>
      <span class="wordmark">Clauderizer</span>
    </a>
    <nav class="links" aria-label="Primary">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>
    <a class="gh" href="https://github.com/collincusce/Clauderizer">
      GitHub <span aria-hidden="true">↗</span>
    </a>
  </div>
</header>

<script>
  // The bar develops a backdrop once the film starts rolling.
  const nav = document.querySelector<HTMLElement>('[data-nav]');
  if (nav) {
    const onScroll = () => nav.classList.toggle('scrolled', window.scrollY > 24);
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>

<style>
  .nav {
    position: fixed;
    inset: 0 0 auto;
    z-index: 60;
    border-bottom: 1px solid transparent;
    transition:
      background 0.35s ease,
      border-color 0.35s ease,
      backdrop-filter 0.35s ease;
  }
  .nav.scrolled {
    backdrop-filter: blur(14px);
    background: rgba(3, 4, 6, 0.68);
    border-bottom-color: var(--edge-subtle);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    gap: 1.6rem;
    padding-block: 0.95rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--cream-50);
  }
  .mark {
    width: 25px;
    height: 25px;
  }
  @media (prefers-reduced-motion: no-preference) {
    .mark circle:last-child {
      animation: orbit 14s linear infinite;
      transform-origin: 16px 16px;
    }
    @keyframes orbit {
      to {
        transform: rotate(360deg);
      }
    }
  }
  .wordmark {
    font-family: var(--font-display);
    font-size: 1.22rem;
    font-weight: 560;
    letter-spacing: 0.005em;
  }
  .links {
    display: flex;
    gap: 1.5rem;
    margin-left: auto;
  }
  .links a {
    text-decoration: none;
    color: var(--cream-200);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding-block: 0.3rem;
    position: relative;
    transition: color 0.16s ease;
  }
  .links a::after {
    content: '';
    position: absolute;
    left: 0;
    right: 100%;
    bottom: 0;
    height: 1px;
    background: var(--ember-400);
    box-shadow: 0 0 8px var(--ember-glow);
    transition: right 0.25s var(--ease-out-expo);
  }
  .links a:hover {
    color: var(--ember-300);
  }
  .links a:hover::after {
    right: 0;
  }
  .gh {
    text-decoration: none;
    color: var(--cream-50);
    border: 1px solid var(--edge-strong);
    padding: 0.52rem 1.05rem;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    white-space: nowrap;
    transition:
      border-color 0.16s ease,
      background 0.16s ease,
      box-shadow 0.16s ease;
  }
  .gh:hover {
    border-color: var(--ember-400);
    background: var(--ember-soft);
    box-shadow: 0 0 18px -4px var(--ember-glow);
  }
  @media (max-width: 720px) {
    .links {
      display: none;
    }
    .gh {
      margin-left: auto;
    }
  }
</style>
