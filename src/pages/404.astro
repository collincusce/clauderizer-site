---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
---

<BaseLayout title="404 · Clauderizer" description="That page slipped out of memory.">
  <Nav />
  <main class="nf">
    <p class="slug"><span class="no">Scene missing</span></p>
    <p class="code">404</p>
    <h1>This frame was cut from the final edit.</h1>
    <p class="lede">
      Even durable memory has its limits. The page you're after isn't in the graph. Let's get you
      back to where things stand.
    </p>
    <a class="btn btn-primary" href="/">← Back to the start</a>
  </main>
  <Footer />
</BaseLayout>

<style>
  .nf {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: clamp(8rem, 24vh, 13rem) 1.5rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.1rem;
    min-height: 62svh;
  }
  .code {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(4rem, 14vw, 7.5rem);
    line-height: 1;
    margin: 0;
    color: var(--ember-400);
    text-shadow: 0 0 50px var(--ember-glow);
  }
  h1 {
    font-size: clamp(1.7rem, 4vw, 2.7rem);
    margin: 0;
  }
  .lede {
    color: var(--cream-200);
    max-width: 34rem;
    margin: 0;
  }
  .btn {
    margin-top: 0.8rem;
  }
</style>
