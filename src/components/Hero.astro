---
// Hero — cinematic opening. Full-bleed video background with the living
// memory-graph layered on top. The poster image is the static / reduced-motion
// fallback (INVARIANT-03).
---

<section class="hero" aria-label="Clauderizer: durable working memory for coding agents">
  <div class="hero-bg" aria-hidden="true">
    <video
      class="hero-video"
      src="/media/hero/hero.mp4"
      autoplay
      muted
      loop
      playsinline
      poster="/media/hero/poster.jpg"
      aria-hidden="true"
    ></video>
    <canvas class="hero-graph" data-graph></canvas>
    <div class="hero-labels" data-graph-labels></div>
    <div class="hero-scrim"></div>
  </div>

  <div class="hero-content container">
    <span class="eyebrow">Durable working memory for coding agents</span>
    <h1>
      Your best ideas<br />
      <span class="amnesiac">shouldn't die in the dark.</span>
    </h1>
    <p class="lede">
      Every session your agent forgets. The architecture. The decision. The momentum.
      Clauderizer gives it a memory that survives — plain Markdown in <code>docs/</code>,
      updated through real tool calls.
    </p>
    <div class="cta-row">
      <a class="btn btn-primary" href="https://github.com/collincusce/Clauderizer">
        Get started on GitHub
      </a>
      <a class="btn btn-ghost" href="#session">See a session come alive →</a>
    </div>
    <button
      class="install"
      type="button"
      data-copy="uvx --from clauderizer clauderize init"
      aria-label="Copy the install command: uvx --from clauderizer clauderize init"
    >
      <code><span class="prompt">$</span> uvx --from clauderizer clauderize init</code>
      <span class="copy-hint">copy</span>
    </button>

    <ul class="hero-legend" aria-label="What the graph nodes represent">
      <li><span class="dot d-phase"></span>phases</li>
      <li><span class="dot d-decision"></span>decisions</li>
      <li><span class="dot d-invariant"></span>invariants</li>
      <li><span class="dot d-subsystem"></span>subsystems</li>
    </ul>
  </div>

  <div class="scroll-cue" aria-hidden="true"><span>scroll</span></div>
</section>

<script>
  import { supportsWebGL, prefersReducedMotion, isCompact } from '@/lib/env';

  const section = document.querySelector<HTMLElement>('.hero');
  const canvas = document.querySelector<HTMLCanvasElement>('.hero-graph');
  const labels = document.querySelector<HTMLElement>('.hero-labels');

  if (section && canvas && supportsWebGL() && !prefersReducedMotion()) {
    const boot = () =>
      import('@/lib/memoryGraph')
        .then(({ initMemoryGraph }) => {
          const graph = initMemoryGraph({ canvas, labelLayer: labels, compact: isCompact() });
          requestAnimationFrame(() => {
            section.classList.add('graph-live');
            setTimeout(() => graph.setCoherence(1), 220);
          });
        })
        .catch(() => {
          /* leave the static poster in place */
        });

    if ('requestIdleCallback' in window) {
      (window as Window & typeof globalThis).requestIdleCallback(boot, { timeout: 1200 });
    } else {
      setTimeout(boot, 200);
    }
  }
</script>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: grid;
    align-items: center;
    overflow: clip;
    background: var(--ink-950);
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-video,
  .hero-graph {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .hero-video {
    object-fit: cover;
    opacity: 0.85;
    transition: opacity 1.2s ease;
  }
  .hero-graph {
    opacity: 0;
    transition: opacity 1.6s ease;
  }
  .hero.graph-live .hero-video {
    opacity: 0.55;
  }
  .hero.graph-live .hero-graph {
    opacity: 1;
  }
  .hero-labels {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
  }
  .hero-scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      radial-gradient(120% 90% at 78% 30%, transparent 26%, rgba(7, 8, 12, 0.7) 100%),
      linear-gradient(
        100deg,
        rgba(7, 8, 12, 0.96) 0%,
        rgba(7, 8, 12, 0.72) 40%,
        rgba(7, 8, 12, 0.18) 78%
      );
  }
  .hero-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding-block: clamp(6rem, 16vh, 10rem);
  }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--amber-400);
  }
  h1 {
    font-size: clamp(2.8rem, 7.5vw, 6rem);
    line-height: 1.02;
    margin: 0;
    font-weight: 800;
    letter-spacing: -0.035em;
    max-width: 16ch;
  }
  .amnesiac {
    color: var(--clay-200);
    -webkit-text-stroke: 0.4px rgba(240, 184, 154, 0.25);
  }
  .lede {
    font-size: clamp(1.08rem, 2.1vw, 1.4rem);
    color: var(--cream-200);
    max-width: 44rem;
    margin: 0;
    line-height: 1.55;
  }
  .lede code {
    font-family: var(--font-mono);
    color: var(--amber-400);
    font-size: 0.92em;
  }
  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 0.4rem;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.9rem 1.6rem;
    border-radius: 999px;
    font-weight: 600;
    text-decoration: none;
    transition:
      transform 0.16s ease,
      background 0.16s ease,
      border-color 0.16s ease,
      box-shadow 0.16s ease;
  }
  .btn-primary {
    background: linear-gradient(180deg, var(--amber-400), var(--amber-600));
    color: #1a1206;
    box-shadow: 0 14px 38px -12px var(--amber-glow-strong);
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 20px 48px -14px var(--amber-glow-strong);
  }
  .btn-ghost {
    color: var(--cream-50);
    border: 1px solid var(--edge-strong);
    background: rgba(7, 8, 12, 0.35);
    backdrop-filter: blur(4px);
  }
  .btn-ghost:hover {
    border-color: var(--amber-400);
    transform: translateY(-2px);
  }
  .install {
    margin-top: 0.6rem;
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
    background: rgba(11, 13, 18, 0.72);
    border: 1px solid var(--edge-strong);
    border-radius: var(--radius-sm);
    padding: 0.85rem 1.1rem;
    cursor: pointer;
    color: var(--cream-50);
    backdrop-filter: blur(8px);
    width: fit-content;
    transition: border-color 0.16s ease;
  }
  .install:hover {
    border-color: var(--amber-400);
  }
  .install code {
    font-family: var(--font-mono);
    font-size: 0.92rem;
  }
  .install .prompt {
    color: var(--amber-400);
  }
  .copy-hint {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--amber-400);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .hero-legend {
    list-style: none;
    margin: 0.8rem 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 1.2rem;
    font-family: var(--font-mono);
    font-size: 0.76rem;
    color: var(--muted);
  }
  .hero-legend li {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }
  .hero-legend .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }
  /* Solid legend swatches — the glow is reserved for the live graph itself,
     not the tiny key beside it. */
  .d-phase {
    background: #e08a5e;
  }
  .d-decision {
    background: #ffb454;
  }
  .d-invariant {
    background: #f4efe6;
  }
  .d-subsystem {
    background: #79a6cf;
  }
  .scroll-cue {
    position: absolute;
    bottom: 1.6rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }
  @media (prefers-reduced-motion: no-preference) {
    .scroll-cue {
      animation: cue 2.4s ease-in-out infinite;
    }
    @keyframes cue {
      0%,
      100% {
        opacity: 0.35;
        transform: translate(-50%, 0);
      }
      50% {
        opacity: 0.9;
        transform: translate(-50%, 6px);
      }
    }
  }
  @media (max-width: 640px) {
    .hero-scrim {
      background: linear-gradient(180deg, rgba(7, 8, 12, 0.45), rgba(7, 8, 12, 0.92));
    }
    .hero-legend {
      gap: 0.9rem;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-video {
      opacity: 0.7;
    }
  }
</style>
