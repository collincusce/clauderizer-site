---
// Hero — recomposed around the living memory-graph (the site's signature WebGL
// centerpiece). Scattered "amnesia" memories bloom into a structured, glowing
// dependency graph as the page loads. The Higgsfield poster is the static
// fallback for no-WebGL / reduced-motion (INVARIANT-03).
---

<section class="hero" aria-label="Clauderizer: durable working memory for coding agents">
  <div class="hero-bg" aria-hidden="true">
    <img class="hero-poster" src="/media/hero/poster.jpg" alt="" decoding="async" fetchpriority="high" />
    <canvas class="hero-graph" data-graph></canvas>
    <div class="hero-labels" data-graph-labels></div>
    <div class="hero-scrim"></div>
  </div>

  <div class="hero-content container">
    <h1>
      Your coding agent is brilliant,<br />
      <span class="amnesiac">and amnesiac.</span>
    </h1>
    <p class="lede">
      Clauderizer gives it a memory that survives: plans, decisions, and a dependency graph as
      plain, Git-diffable Markdown it reads and updates through real tool calls.
    </p>
    <div class="cta-row">
      <a class="btn btn-primary" href="https://github.com/collincusce/Clauderizer">
        Get started on GitHub
      </a>
      <a class="btn btn-ghost" href="#session">Watch a session →</a>
    </div>
    <button
      class="install"
      type="button"
      data-copy="uvx --from clauderizer clauderize init"
      aria-label="Copy the install command: uvx --from clauderizer clauderize init"
    >
      <code><span class="prompt">$</span> uvx --from clauderizer clauderize init</code>
      <span class="copy-hint">copy</span>
    </button>

    <ul class="hero-legend" aria-label="What the graph nodes represent">
      <li><span class="dot d-phase"></span>phases</li>
      <li><span class="dot d-decision"></span>decisions</li>
      <li><span class="dot d-invariant"></span>invariants</li>
      <li><span class="dot d-subsystem"></span>subsystems</li>
    </ul>
  </div>

  <div class="scroll-cue" aria-hidden="true"><span>scroll to remember</span></div>
</section>

<script>
  import { supportsWebGL, prefersReducedMotion, isCompact } from '@/lib/env';

  const section = document.querySelector<HTMLElement>('.hero');
  const canvas = document.querySelector<HTMLCanvasElement>('.hero-graph');
  const labels = document.querySelector<HTMLElement>('.hero-labels');

  // Three.js is heavy, so it's dynamically imported — code-split into its own
  // chunk that only loads when the enhanced path will actually run. The static
  // poster carries the hero until (and unless) the graph is ready.
  if (section && canvas && supportsWebGL() && !prefersReducedMotion()) {
    const boot = () =>
      import('@/lib/memoryGraph')
        .then(({ initMemoryGraph }) => {
          const graph = initMemoryGraph({ canvas, labelLayer: labels, compact: isCompact() });
          requestAnimationFrame(() => {
            section.classList.add('graph-live');
            // small delay so the first frame paints at "fog" before blooming
            setTimeout(() => graph.setCoherence(1), 220);
          });
        })
        .catch(() => {
          /* leave the static poster in place */
        });

    if ('requestIdleCallback' in window) {
      (window as Window & typeof globalThis).requestIdleCallback(boot, { timeout: 1200 });
    } else {
      setTimeout(boot, 200);
    }
  }
</script>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: grid;
    align-items: center;
    overflow: clip;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-poster,
  .hero-graph {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .hero-poster {
    object-fit: cover;
    opacity: 0.9;
    transition: opacity 1.1s ease;
  }
  .hero-graph {
    opacity: 0;
    transition: opacity 1.4s ease;
  }
  /* When the live graph is running, fade the poster down to a faint base glow. */
  .hero.graph-live .hero-poster {
    opacity: 0.16;
  }
  .hero.graph-live .hero-graph {
    opacity: 1;
  }
  .hero-labels {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
  }
  .hero-scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      radial-gradient(115% 90% at 78% 38%, transparent 36%, rgba(8, 9, 13, 0.5) 100%),
      linear-gradient(
        90deg,
        rgba(8, 9, 13, 0.94) 0%,
        rgba(8, 9, 13, 0.66) 42%,
        rgba(8, 9, 13, 0.08) 78%
      );
  }
  .hero-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    padding-block: clamp(6rem, 14vh, 9rem);
  }
  h1 {
    font-size: clamp(2.5rem, 6.6vw, 5.1rem);
    line-height: 1.03;
    margin: 0;
    font-weight: 800;
    letter-spacing: -0.025em;
    max-width: 18ch;
  }
  .amnesiac {
    color: var(--muted);
    -webkit-text-stroke: 0.4px rgba(139, 145, 161, 0.3);
  }
  .lede {
    font-size: clamp(1.05rem, 2vw, 1.32rem);
    color: var(--cream-200);
    max-width: 40rem;
    margin: 0;
  }
  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 0.3rem;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.82rem 1.4rem;
    border-radius: 999px;
    font-weight: 600;
    text-decoration: none;
    transition:
      transform 0.16s ease,
      background 0.16s ease,
      border-color 0.16s ease,
      box-shadow 0.16s ease;
  }
  .btn-primary {
    background: linear-gradient(180deg, var(--amber-400), var(--clay));
    color: #20140a;
    box-shadow: 0 12px 34px -12px var(--clay-glow);
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 44px -14px var(--clay-glow);
  }
  .btn-ghost {
    color: var(--cream-50);
    border: 1px solid var(--edge-strong);
  }
  .btn-ghost:hover {
    border-color: var(--clay);
    transform: translateY(-2px);
  }
  .install {
    margin-top: 0.5rem;
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
    background: rgba(14, 17, 23, 0.72);
    border: 1px solid var(--edge);
    border-radius: var(--radius);
    padding: 0.85rem 1.1rem;
    cursor: pointer;
    color: var(--cream-50);
    backdrop-filter: blur(8px);
    width: fit-content;
  }
  .install:hover {
    border-color: var(--clay);
  }
  .install code {
    font-family: var(--font-mono);
    font-size: 0.92rem;
  }
  .install .prompt {
    color: var(--clay);
  }
  .copy-hint {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--clay);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .hero-legend {
    list-style: none;
    margin: 0.6rem 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 1.2rem;
    font-family: var(--font-mono);
    font-size: 0.76rem;
    color: var(--muted);
  }
  .hero-legend li {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }
  .hero-legend .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }
  /* Solid legend swatches — the glow is reserved for the live graph itself,
     not the tiny key beside it. */
  .d-phase {
    background: #e08a5e;
  }
  .d-decision {
    background: #ffb454;
  }
  .d-invariant {
    background: #f4efe6;
  }
  .d-subsystem {
    background: #79a6cf;
  }
  .scroll-cue {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
  }
  @media (prefers-reduced-motion: no-preference) {
    .scroll-cue {
      animation: cue 2.4s ease-in-out infinite;
    }
    @keyframes cue {
      0%,
      100% {
        opacity: 0.35;
        transform: translate(-50%, 0);
      }
      50% {
        opacity: 0.9;
        transform: translate(-50%, 6px);
      }
    }
  }
  @media (max-width: 640px) {
    .hero-scrim {
      background: linear-gradient(180deg, rgba(8, 9, 13, 0.5), rgba(8, 9, 13, 0.88));
    }
    .hero-legend {
      gap: 0.9rem;
    }
  }
</style>
