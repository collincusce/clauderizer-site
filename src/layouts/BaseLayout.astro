---
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Clauderizer — stop re-explaining your project to your AI',
  description =
    'Clauderizer is a memory system for coding agents — plans, decisions, and conventions as Markdown in your repo, briefed to your agent every session.',
} = Astro.props;

const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site) : undefined;
const ogImage = Astro.site ? new URL('/og-2026.jpg', Astro.site).href : '/og-2026.jpg';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Clauderizer',
  applicationCategory: 'DeveloperApplication',
  applicationSubCategory: 'Coding agent memory',
  operatingSystem: 'Linux, macOS, Windows (WSL)',
  description,
  url: 'https://clauderizer.com',
  image: ogImage,
  downloadUrl: 'https://pypi.org/project/clauderizer/',
  installUrl: 'https://pypi.org/project/clauderizer/',
  codeRepository: 'https://github.com/collincusce/Clauderizer',
  softwareRequirements: 'Python 3.11+',
  license: 'https://www.apache.org/licenses/LICENSE-2.0',
  isAccessibleForFree: true,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  author: { '@type': 'Person', name: 'Collin Cusce' },
  keywords:
    'coding agent memory, AI pair programming, MCP server, Model Context Protocol, cross-session context, persistent memory, dependency graph, Claude Code, Cursor, GitHub Copilot, Grok',
  featureList: [
    'Durable cross-session memory for AI coding agents',
    'Plans, decisions, and invariants as Git-diffable Markdown',
    'Self-describing MCP tools and lifecycle hooks',
    'Dependency graph with cascade and preflight',
    'Host-portable across Claude Code, Cursor, Copilot, Codex, Gemini, Grok, and more',
    'Apache 2.0 licensed with zero runtime dependencies',
  ],
  sameAs: ['https://github.com/collincusce/Clauderizer', 'https://pypi.org/project/clauderizer/'],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {canonical && <link rel="canonical" href={canonical.href} />}
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Icons + manifest -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" sizes="32x32" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#05070a" />
    <meta name="color-scheme" content="dark" />

    <!-- Self-hosted display + mono faces -->
    <link
      rel="preload"
      href="/fonts/bodonimoda-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/jetbrainsmono-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Clauderizer" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonical && <meta property="og:url" content={canonical.href} />}
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="Clauderizer: stop re-explaining your project to your AI."
    />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="generator" content={Astro.generator} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <slot />

    <!-- Cinematic film layer (decorative; pointer-events:none) -->
    <div class="fx" aria-hidden="true">
      <canvas class="fx-particles"></canvas>
      <div class="fx-grade"></div>
      <div class="fx-vignette"></div>
      <div class="fx-grain"></div>
    </div>

    <script>
      // Animation governor (O-07): pause perpetual CSS animations when the tab
      // is hidden, and pause any [data-anim] block when it scrolls offscreen.
      document.addEventListener('visibilitychange', () => {
        document.body.classList.toggle('anim-paused', document.hidden);
      });
      const pausables = document.querySelectorAll('[data-anim]');
      if ('IntersectionObserver' in window && pausables.length) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) e.target.classList.toggle('anim-off', !e.isIntersecting);
          },
          { rootMargin: '140px' },
        );
        pausables.forEach((el) => io.observe(el));
      }
    </script>

    <script>
      const canvas = document.querySelector<HTMLCanvasElement>('.fx-particles');
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)');
      const ctx = canvas?.getContext('2d');

      if (canvas && ctx && !reduce.matches) {
        const small = window.matchMedia('(max-width: 640px)').matches;
        const COUNT = small ? 18 : 46;
        let w = 0,
          h = 0,
          dpr = 1,
          raf = 0,
          t = 0;
        type P = {
          x: number;
          y: number;
          r: number;
          vy: number;
          vx: number;
          a: number;
          tw: number;
          sway: number;
        };
        let parts: P[] = [];

        const resize = () => {
          dpr = Math.min(window.devicePixelRatio || 1, 2);
          w = canvas.width = Math.floor(window.innerWidth * dpr);
          h = canvas.height = Math.floor(window.innerHeight * dpr);
          canvas.style.width = window.innerWidth + 'px';
          canvas.style.height = window.innerHeight + 'px';
        };
        const seed = () => {
          parts = Array.from({ length: COUNT }, () => ({
            x: Math.random() * w,
            y: Math.random() * h,
            r: (Math.random() * 1.6 + 0.35) * dpr,
            vy: -(Math.random() * 0.2 + 0.04) * dpr,
            vx: (Math.random() - 0.5) * 0.08 * dpr,
            a: Math.random() * 0.45 + 0.12,
            tw: Math.random() * Math.PI * 2,
            sway: Math.random() * 0.5 + 0.15,
          }));
        };
        const frame = () => {
          t += 0.006;
          ctx.clearRect(0, 0, w, h);
          for (const p of parts) {
            p.y += p.vy;
            p.x += p.vx + Math.sin(t * 2 + p.tw) * 0.06 * p.sway * dpr;
            p.tw += 0.018;
            if (p.y < -12) {
              p.y = h + 12;
              p.x = Math.random() * w;
            }
            if (p.x < -12) p.x = w + 12;
            if (p.x > w + 12) p.x = -12;
            const glow = p.r > 1.4 * dpr;
            if (glow) {
              ctx.shadowColor = 'rgba(245,158,11,0.85)';
              ctx.shadowBlur = 7 * dpr;
            } else {
              ctx.shadowBlur = 0;
            }
            ctx.beginPath();
            ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
            ctx.fillStyle = `rgba(255,186,96,${p.a * (0.55 + 0.45 * Math.sin(p.tw))})`;
            ctx.fill();
          }
          ctx.shadowBlur = 0;
          raf = requestAnimationFrame(frame);
        };

        resize();
        seed();
        frame();
        window.addEventListener(
          'resize',
          () => {
            resize();
            seed();
          },
          { passive: true },
        );
        document.addEventListener('visibilitychange', () => {
          if (document.hidden) {
            cancelAnimationFrame(raf);
            raf = 0;
          } else if (!raf) {
            raf = requestAnimationFrame(frame);
          }
        });
      }

      // Global copy-to-clipboard for any [data-copy] button.
      document.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest<HTMLElement>('[data-copy]');
        if (!btn) return;
        navigator.clipboard
          ?.writeText(btn.dataset.copy ?? '')
          .then(() => {
            const hint = btn.querySelector('.copy-hint');
            if (hint) {
              const prev = hint.textContent;
              hint.textContent = 'copied';
              setTimeout(() => (hint.textContent = prev), 1400);
            }
          })
          .catch(() => {});
      });
    </script>
  </body>
</html>
