---
const links = [
  { href: '#how-it-works', label: 'How it works' },
  { href: '#features', label: 'Features' },
  { href: '#quickstart', label: 'Quickstart' },
  { href: '#faq', label: 'FAQ' },
];
---

<header class="nav" id="top">
  <div class="nav-inner container">
    <a class="brand" href="#top" aria-label="Clauderizer home">
      <svg class="mark" viewBox="0 0 32 32" aria-hidden="true">
        <circle cx="16" cy="16" r="8" fill="none" stroke="var(--amber-500)" stroke-width="3"></circle>
        <circle cx="16" cy="16" r="2.6" fill="var(--amber-400)"></circle>
      </svg>
      <span>Clauderizer</span>
    </a>
    <nav class="links" aria-label="Primary">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>
    <a class="gh" href="https://github.com/collincusce/Clauderizer">GitHub ↗</a>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(12px);
    background: rgba(7, 8, 12, 0.65);
    border-bottom: 1px solid var(--edge);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding-block: 0.85rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-weight: 700;
    text-decoration: none;
    letter-spacing: -0.01em;
    color: var(--cream-50);
  }
  .mark {
    width: 24px;
    height: 24px;
  }
  .links {
    display: flex;
    gap: 1.4rem;
    margin-left: auto;
  }
  .links a {
    text-decoration: none;
    color: var(--cream-200);
    font-size: 0.95rem;
    transition: color 0.15s ease;
  }
  .links a:hover {
    color: var(--amber-400);
  }
  .gh {
    text-decoration: none;
    color: var(--cream-50);
    border: 1px solid var(--edge-strong);
    padding: 0.55rem 1rem;
    border-radius: 999px;
    font-size: 0.9rem;
    font-weight: 500;
    white-space: nowrap;
    transition:
      border-color 0.15s ease,
      background 0.15s ease;
  }
  .gh:hover {
    border-color: var(--amber-400);
    background: rgba(245, 158, 11, 0.08);
  }
  @media (max-width: 720px) {
    .links {
      display: none;
    }
    .gh {
      margin-left: auto;
    }
  }
</style>
