---
// "Why it holds" — an editorial spec sheet rather than a grid of identical
// icon-tiles. Each capability is a term + definition row separated by
// hairlines, so the names carry the section and the eye reads down a spine
// instead of scanning five interchangeable cards.
const features = [
  {
    t: 'Discoverable',
    d: 'Self-describing MCP tools + lifecycle hooks inject status into context automatically. No "read these 7 files in this order" ritual.',
  },
  {
    t: 'Configurable',
    d: 'Three project sizes (pet, standard, and SaaS) plus host-language profiles: configuration as data, not prose advice.',
  },
  {
    t: 'Agentic',
    d: 'Cascade, pre-flight, and handoff assembly are real tool calls, not instructions the agent has to remember to run.',
  },
  {
    t: 'Drop-in',
    d: 'One command clauderizes any repository, in any language. Idempotent; never clobbers your files.',
  },
  {
    t: 'Host-portable',
    d: 'One install targets Claude Code, Cursor, Copilot, Codex, Gemini, Windsurf, Cline, Amp, Continue, Zed, or kimi.',
  },
];
---

<section class="section features" id="features">
  <div class="container">
    <p class="kicker reveal reveal-sm">Why it holds</p>
    <h2 class="reveal">A system, not a hope.</h2>
    <p class="sub reveal">
      Prose conventions rot because nothing executes them. Clauderizer keeps the proven model and
      makes it real tool calls the agent can't forget to make.
    </p>

    <dl class="specs">
      {
        features.map((f) => (
          <div class="spec reveal">
            <dt>{f.t}</dt>
            <dd>{f.d}</dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>

<style>
  .features {
    background: linear-gradient(180deg, var(--ink-900), var(--ink-800));
  }
  .sub {
    max-width: 46rem;
    color: var(--cream-200);
    font-size: clamp(1.02rem, 1.7vw, 1.18rem);
    margin: 0 0 2.4rem;
  }
  .specs {
    margin: 0;
    border-top: 1px solid var(--edge);
  }
  .spec {
    display: grid;
    grid-template-columns: minmax(0, 14rem) 1fr;
    gap: 0.4rem 2.6rem;
    align-items: baseline;
    padding: 1.35rem 0;
    border-bottom: 1px solid var(--edge);
  }
  .spec dt {
    font-size: 1.18rem;
    font-weight: 700;
    color: var(--cream-50);
    letter-spacing: -0.01em;
  }
  .spec dd {
    margin: 0;
    max-width: 46rem;
    color: var(--cream-200);
    font-size: 0.98rem;
    line-height: 1.6;
  }
  @media (max-width: 640px) {
    .spec {
      grid-template-columns: 1fr;
      gap: 0.35rem;
      padding: 1.15rem 0;
    }
  }
</style>
