---
// How it works: reframe Markdown-in-docs as durability and permanence.
const stages = [
  {
    t: 'Markdown in docs/',
    d: 'Plans, decisions, invariants, a dependency graph — all diffable, reviewable, and shipped with the code.',
  },
  {
    t: 'The engine',
    d: 'Reads and writes the Markdown, rebuilds the graph cache, and runs preflight and cascade against the real repository.',
  },
  {
    t: 'MCP tools + hooks',
    d: 'Self-describing tool calls and lifecycle hooks inject status into context, automatically.',
  },
  {
    t: 'Your agent',
    d: 'Oriented before you type a word. No prescribed reading order, no re-briefing, no drift.',
  },
];

const loop = [
  { call: 'cz_next_phase_context', out: 'the full bundle for this phase' },
  { call: 'cz_preflight', out: 'actually runs your tests / build' },
  { call: '… do the work …', out: 'write code, honour the invariants', work: true },
  { call: 'cz_add_decision · cz_add_invariant', out: 'structured, graph-aware records' },
  { call: 'cz_cascade', out: 'walk the graph, flag dependents' },
  { call: 'cz_write_handoff', out: 'assemble the next cumulative handoff' },
];
---

<section class="section how" id="how-it-works">
  <div class="media-bg parallax parallax-mid" aria-hidden="true">
    <img src="/media/hero/flux2.png" alt="" loading="lazy" decoding="async" />
    <div class="scrim"></div>
  </div>

  <div class="container">
    <p class="kicker reveal reveal-sm">How it works</p>
    <h2 class="reveal">Your memory is just readable files in docs/.</h2>
    <p class="sub reveal">
      No database. No proprietary cloud. The graph index is a disposable cache, rebuilt from the
      Markdown on demand. If they ever disagree, Markdown wins. Your ideas survive as plain text.
    </p>

    <ol class="pipeline reveal">
      {
        stages.map((s, i) => (
          <li class="stage">
            <span class="idx">{String(i + 1).padStart(2, '0')}</span>
            <b>{s.t}</b>
            <p>{s.d}</p>
            {i < stages.length - 1 && (
              <span class="flow" aria-hidden="true">
                →
              </span>
            )}
          </li>
        ))
      }
    </ol>

    <figure class="loop reveal" aria-label="A typical phase loop: the cz_* tool calls a session runs, in order">
      <figcaption>
        <span class="loop-title">A typical phase loop</span>
        <span class="loop-hint">runs every session →</span>
      </figcaption>
      <ol class="loop-track" role="list" data-anim>
        {
          loop.map((step, i) => (
            <li class:list={['loop-step', { work: step.work }]} style={`--i:${i}`}>
              <span class="loop-dot" aria-hidden="true" />
              <code class="loop-call">{step.call}</code>
              <span class="loop-out">{step.out}</span>
            </li>
          ))
        }
        <li class="loop-return" aria-hidden="true">
          <span class="loop-dot return" />
          <span class="loop-out">↺ next session picks up exactly here</span>
        </li>
      </ol>
    </figure>
  </div>
</section>

<style>
  .how {
    background: var(--ink-900);
  }
  .media-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  .media-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .scrim {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(120% 90% at 80% 40%, transparent 25%, rgba(7, 8, 12, 0.92) 100%),
      linear-gradient(180deg, rgba(7, 8, 12, 0.4), rgba(7, 8, 12, 0.85));
  }
  .container {
    position: relative;
    z-index: 1;
  }
  .sub {
    max-width: 48rem;
    color: var(--cream-200);
    font-size: clamp(1.05rem, 1.8vw, 1.22rem);
    margin: 0 0 2.8rem;
    line-height: 1.6;
  }
  .sub code,
  .loop code {
    font-family: var(--font-mono);
  }

  .pipeline {
    list-style: none;
    margin: 0 0 3.2rem;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 14rem), 1fr));
    gap: 1.2rem;
  }
  .stage {
    position: relative;
    padding: 1.6rem;
    border: 1px solid var(--edge);
    border-radius: var(--radius);
    background: rgba(11, 13, 18, 0.72);
    backdrop-filter: blur(6px);
    transition:
      border-color 0.2s ease,
      transform 0.2s ease;
  }
  .stage:hover {
    border-color: var(--clay-soft);
    transform: translateY(-4px);
  }
  .stage .idx {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--clay);
  }
  .stage b {
    display: block;
    margin: 0.45rem 0 0.55rem;
    font-size: 1.14rem;
  }
  .stage p {
    margin: 0;
    color: var(--cream-200);
    font-size: 0.97rem;
    line-height: 1.6;
  }
  .stage .flow {
    position: absolute;
    right: -1rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--clay);
    font-size: 1.2rem;
    z-index: 2;
  }
  @media (max-width: 640px) {
    .stage .flow {
      right: 50%;
      top: auto;
      bottom: -1rem;
      transform: translateX(50%) rotate(90deg);
    }
  }

  .loop {
    margin: 0;
    border: 1px solid var(--edge);
    border-radius: var(--radius);
    background: rgba(11, 13, 18, 0.82);
    backdrop-filter: blur(6px);
    overflow: hidden;
    max-width: 48rem;
  }
  .loop figcaption {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.95rem 1.25rem;
    border-bottom: 1px solid var(--edge);
  }
  .loop-title {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    color: var(--clay);
  }
  .loop-hint {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--muted);
  }
  .loop-track {
    list-style: none;
    margin: 0;
    padding: 1.2rem 1.3rem 1.4rem;
    position: relative;
  }
  .loop-track::before {
    content: '';
    position: absolute;
    left: calc(1.3rem + 6px);
    top: 1.8rem;
    bottom: 2.2rem;
    width: 2px;
    background: var(--edge-strong);
  }
  .loop-step,
  .loop-return {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: baseline;
    column-gap: 0.9rem;
    padding: 0.48rem 0;
    padding-left: 0.1rem;
  }
  .loop-dot {
    position: relative;
    z-index: 1;
    width: 14px;
    height: 14px;
    margin-top: 0.18rem;
    border-radius: 50%;
    border: 2px solid #2a3340;
    background: var(--ink-900);
    transition:
      background 0.3s ease,
      border-color 0.3s ease,
      box-shadow 0.3s ease,
      transform 0.3s ease;
  }
  .loop-call {
    font-family: var(--font-mono);
    font-size: 0.88rem;
    color: var(--cream-200);
    grid-column: 2;
    transition: color 0.3s ease;
  }
  .loop-step.work .loop-call {
    color: var(--muted);
    font-style: italic;
  }
  .loop-out {
    grid-column: 2;
    font-size: 0.8rem;
    color: var(--muted);
    opacity: 0.4;
    transition: opacity 0.35s ease;
  }
  .loop-return .loop-out {
    grid-column: 2;
    opacity: 1;
    color: var(--clay);
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }
  .loop-return .loop-dot.return {
    border-color: var(--clay);
    background: var(--clay-soft);
  }

  @media (prefers-reduced-motion: no-preference) {
    .loop-step {
      animation: loop-fire 9s linear infinite;
      animation-delay: calc(var(--i) * -1.5s);
    }
    .loop-step .loop-dot {
      animation: loop-dot 9s linear infinite;
      animation-delay: calc(var(--i) * -1.5s);
    }
    .loop-step .loop-out {
      animation: loop-out 9s linear infinite;
      animation-delay: calc(var(--i) * -1.5s);
    }
    @keyframes loop-dot {
      0%,
      3% {
        background: var(--ink-900);
        border-color: #2a3340;
        box-shadow: none;
        transform: scale(1);
      }
      8%,
      14% {
        background: var(--clay);
        border-color: var(--clay);
        box-shadow: 0 0 0 5px var(--clay-soft);
        transform: scale(1.18);
      }
      22%,
      100% {
        background: var(--ink-900);
        border-color: #2a3340;
        box-shadow: none;
        transform: scale(1);
      }
    }
    @keyframes loop-fire {
      0%,
      3%,
      22%,
      100% {
        color: inherit;
      }
    }
    @keyframes loop-out {
      0%,
      6% {
        opacity: 0.25;
        transform: translateY(-2px);
      }
      10%,
      20% {
        opacity: 1;
        transform: translateY(0);
      }
      26%,
      100% {
        opacity: 0.25;
        transform: translateY(-2px);
      }
    }
    .loop-step .loop-call {
      animation: loop-call 9s linear infinite;
      animation-delay: calc(var(--i) * -1.5s);
    }
    @keyframes loop-call {
      0%,
      5% {
        color: var(--cream-200);
      }
      9%,
      18% {
        color: var(--clay-200);
      }
      24%,
      100% {
        color: var(--cream-200);
      }
    }
    .loop-step.work .loop-call {
      animation: none;
    }
  }
</style>
