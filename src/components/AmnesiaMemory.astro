---
// Same agent, same repo — the WITHOUT/WITH ledger, now with a visual
// before/after sequence and more emotional language.
const without = [
  'You re-explain the architecture. Again.',
  'A decision from an hour ago, contradicted.',
  '“Wait… did we already build this?”',
  'The plan drifts from reality, silently.',
];
const withCz = [
  'The digest greets the agent at session start.',
  'Decisions & invariants surface, not re-derived.',
  '“Phase 4 of 10, preflight passed, building.”',
  'The plan is the live state.',
];
const frames = [
  { src: '/media/hero/bf0.jpg', alt: 'Fragmented memory' },
  { src: '/media/hero/bf1.jpg', alt: 'Memory resolving' },
  { src: '/media/hero/bf2.jpg', alt: 'Structured memory' },
];
---

<section class="section am" id="memory">
  <div class="container">
    <p class="kicker reveal reveal-sm">Same agent, same repo</p>
    <h2 class="reveal">One of them remembers.</h2>

    <div class="ledger">
      <article class="panel forget reveal">
        <header><span class="tag">Without Clauderizer</span></header>
        <ul>
          {
            without.map((t, i) => (
              <li style={`--d:${i}`}>
                <span class="mark bad" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="14" height="14">
                    <path
                      d="M7 7l10 10M17 7L7 17"
                      stroke="currentColor"
                      stroke-width="2.4"
                      stroke-linecap="round"
                      fill="none"
                    />
                  </svg>
                </span>
                <span>{t}</span>
              </li>
            ))
          }
        </ul>
        <p class="foot">every session starts from zero</p>
      </article>

      <div class="bridge reveal" aria-hidden="true">
        <div class="frames">
          {frames.map((f, i) => <img src={f.src} alt={f.alt} class={`frame f${i}`} loading="lazy" decoding="async" />)}
        </div>
        <span class="bridge-arrow">→</span>
      </div>

      <article class="panel remember reveal">
        <header><span class="tag">With Clauderizer</span></header>
        <ul>
          {
            withCz.map((t, i) => (
              <li style={`--d:${i}`}>
                <span class="mark ok" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="14" height="14">
                    <path
                      d="M5 12.5l4.5 4.5L19 7.5"
                      stroke="currentColor"
                      stroke-width="2.4"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      fill="none"
                    />
                  </svg>
                </span>
                <span>{t}</span>
              </li>
            ))
          }
        </ul>
        <p class="foot ok-foot">every session is momentum →</p>
      </article>
    </div>
  </div>
</section>

<style>
  .am {
    background: linear-gradient(180deg, var(--ink-900), var(--ink-800));
  }
  .ledger {
    margin-top: 2.8rem;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 1.6rem;
    align-items: stretch;
  }
  .panel {
    border-radius: var(--radius);
    border: 1px solid var(--edge);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    transition:
      transform 0.18s ease,
      border-color 0.18s ease;
  }
  .panel:hover {
    transform: translateY(-3px);
  }
  .panel header {
    margin-bottom: 1.2rem;
  }
  .panel .tag {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .panel ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    flex: 1;
  }
  .panel li {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.75rem;
    align-items: start;
    line-height: 1.5;
  }
  .mark {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    margin-top: 0.05rem;
  }
  .mark.bad {
    color: var(--bad);
    background: var(--bad-soft);
    border: 1px solid var(--bad-line);
  }
  .mark.ok {
    color: var(--ok);
    background: var(--ok-soft);
    border: 1px solid var(--ok-line);
  }
  .foot {
    margin: 1.6rem 0 0;
    font-size: 0.88rem;
    font-style: italic;
  }

  .forget {
    background: rgba(20, 22, 28, 0.55);
    filter: saturate(0.5);
  }
  .forget:hover {
    border-color: var(--bad-line);
  }
  .forget .tag {
    color: var(--muted);
  }
  .forget li span:last-child {
    color: var(--muted);
  }
  .forget .foot {
    color: var(--dim);
  }

  .remember {
    background:
      radial-gradient(130% 120% at 100% 0%, var(--ok-soft), transparent 58%),
      rgba(13, 17, 14, 0.72);
    border-color: var(--ok-line);
    box-shadow: 0 28px 70px -44px rgba(87, 194, 74, 0.45);
  }
  .remember:hover {
    border-color: rgba(87, 194, 74, 0.6);
  }
  .remember .tag {
    color: var(--ok);
  }
  .remember li span:last-child {
    color: var(--cream-50);
  }
  .remember .ok-foot {
    color: var(--ok);
    font-weight: 600;
    font-style: normal;
    font-family: var(--font-mono);
    font-size: 0.82rem;
  }

  .bridge {
    display: grid;
    place-items: center;
    position: relative;
    min-width: 12rem;
  }
  .frames {
    position: relative;
    width: 100%;
    aspect-ratio: 1470 / 630;
    border-radius: var(--radius-sm);
    overflow: hidden;
    border: 1px solid var(--edge);
  }
  .frame {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.6s ease;
  }
  .frame.f0 {
    opacity: 1;
  }
  @media (prefers-reduced-motion: no-preference) {
    .frames:hover .frame.f0,
    .frames:hover .frame.f1 {
      opacity: 0;
    }
    .frames:hover .frame.f2 {
      opacity: 1;
    }
    .frames:hover .frame.f1 {
      opacity: 1;
      transition-delay: 0.25s;
    }
    .frames:hover .frame.f0 {
      opacity: 0;
    }
  }
  .bridge-arrow {
    position: absolute;
    bottom: -1.8rem;
    font-size: 1.6rem;
    color: var(--clay);
  }

  @media (max-width: 900px) {
    .ledger {
      grid-template-columns: 1fr;
    }
    .bridge {
      height: 10rem;
      min-width: auto;
    }
    .bridge-arrow {
      transform: rotate(90deg);
      bottom: auto;
      right: -1rem;
    }
  }
</style>
