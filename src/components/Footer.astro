---
// End credits. Every good film rolls them.
const cols = [
  {
    h: 'Product',
    links: [
      { t: 'How it works', href: '#how-it-works' },
      { t: 'Features', href: '#features' },
      { t: 'Quickstart', href: '#quickstart' },
      { t: 'FAQ', href: '#faq' },
    ],
  },
  {
    h: 'Source',
    links: [
      { t: 'GitHub', href: 'https://github.com/collincusce/Clauderizer' },
      { t: 'PyPI', href: 'https://pypi.org/project/clauderizer/' },
      {
        t: 'License (Apache 2.0)',
        href: 'https://github.com/collincusce/Clauderizer/blob/main/LICENSE',
      },
    ],
  },
];
---

<footer class="footer">
  <div class="container credits">
    <p class="slug"><span class="no">End credits</span></p>
    <p class="wordmark">Clauderizer</p>
    <ul class="roll" aria-label="Production credits">
      <li><span class="role">Directed by</span><span class="name">dogfooding itself</span></li>
      <li><span class="role">Starring</span><span class="name">your coding agent</span></li>
      <li><span class="role">Memory by</span><span class="name">Markdown in docs/</span></li>
      <li>
        <span class="role">Shot on location in</span><span class="name">your repository</span>
      </li>
    </ul>
  </div>

  <div class="container top">
    {
      cols.map((c) => (
        <nav class="col" aria-label={c.h}>
          <h3>{c.h}</h3>
          {c.links.map((l) => (
            <a href={l.href}>{l.t}</a>
          ))}
        </nav>
      ))
    }
  </div>

  <div class="container bottom">
    <span>Durable working memory for coding agents · Apache 2.0</span>
    <span class="fin">fin. <i aria-hidden="true">◼</i></span>
  </div>
</footer>

<style>
  .footer {
    background: var(--ink-950);
    padding-block: 3.2rem 2rem;
  }
  .credits {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin-bottom: 2rem;
  }
  .wordmark {
    font-family: var(--font-display);
    font-weight: 520;
    font-size: clamp(2.3rem, 5vw, 3.5rem);
    letter-spacing: -0.02em;
    line-height: 1;
    margin: 0.3rem 0 1.3rem;
    background: linear-gradient(180deg, var(--cream-50), var(--cream-300));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .roll {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .roll li {
    display: flex;
    gap: 0.9rem;
    align-items: baseline;
    font-size: 0.92rem;
  }
  .role {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--dim);
    min-width: 15ch;
    text-align: right;
  }
  .name {
    color: var(--cream-200);
    text-align: left;
  }

  .top {
    display: flex;
    justify-content: center;
    gap: clamp(2.5rem, 10vw, 7rem);
    padding-top: 1.7rem;
    border-top: 1px solid var(--edge-subtle);
  }
  .col {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    align-items: center;
    text-align: center;
  }
  .col h3 {
    margin: 0 0 0.3rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--muted);
    font-weight: 500;
  }
  .col a {
    text-decoration: none;
    color: var(--cream-200);
    font-size: 0.94rem;
    transition: color 0.15s ease;
  }
  .col a:hover {
    color: var(--ember-300);
  }
  .bottom {
    margin-top: 2rem;
    padding-top: 1.2rem;
    border-top: 1px solid var(--edge-subtle);
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
    color: var(--muted);
    font-size: 0.85rem;
  }
  .fin {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--cream-300);
    letter-spacing: 0.02em;
  }
  .fin i {
    font-style: normal;
    font-size: 0.6em;
    color: var(--ember-400);
    vertical-align: 0.12em;
    margin-left: 0.2rem;
  }
  @media (max-width: 560px) {
    .roll li {
      flex-direction: column;
      gap: 0.05rem;
      align-items: center;
    }
    .role,
    .name {
      text-align: center;
      min-width: 0;
    }
  }
</style>
