---
const cols = [
  {
    h: 'Product',
    links: [
      { t: 'How it works', href: '#how-it-works' },
      { t: 'Features', href: '#features' },
      { t: 'Quickstart', href: '#quickstart' },
      { t: 'FAQ', href: '#faq' },
    ],
  },
  {
    h: 'Source',
    links: [
      { t: 'GitHub', href: 'https://github.com/collincusce/Clauderizer' },
      { t: 'PyPI', href: 'https://pypi.org/project/clauderizer/' },
      { t: 'License (Apache 2.0)', href: 'https://github.com/collincusce/Clauderizer/blob/main/LICENSE' },
    ],
  },
];
---

<footer class="footer">
  <div class="container top">
    <a class="brand" href="#top" aria-label="Clauderizer home">
      <svg class="mark" viewBox="0 0 32 32" aria-hidden="true">
        <circle cx="16" cy="16" r="8" fill="none" stroke="var(--amber-500)" stroke-width="3"></circle>
        <circle cx="16" cy="16" r="2.6" fill="var(--amber-400)"></circle>
      </svg>
      <span>Clauderizer</span>
    </a>
    {
      cols.map((c) => (
        <nav class="col" aria-label={c.h}>
          <h3>{c.h}</h3>
          {c.links.map((l) => (
            <a href={l.href}>{l.t}</a>
          ))}
        </nav>
      ))
    }
  </div>
  <div class="container bottom">
    <span>Durable working memory for coding agents, built by dogfooding itself.</span>
    <span>Apache 2.0 licensed</span>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--edge);
    background: var(--ink-950);
    padding-block: 3.5rem 2.5rem;
  }
  .top {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: 2rem;
    align-items: start;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-weight: 700;
    text-decoration: none;
    color: var(--cream-50);
  }
  .mark {
    width: 24px;
    height: 24px;
  }
  .col {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .col h3 {
    margin: 0 0 0.3rem;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    font-weight: 500;
  }
  .col a {
    text-decoration: none;
    color: var(--cream-200);
    font-size: 0.95rem;
    transition: color 0.15s ease;
  }
  .col a:hover {
    color: var(--amber-400);
  }
  .bottom {
    margin-top: 2.8rem;
    padding-top: 1.6rem;
    border-top: 1px solid var(--edge);
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    color: var(--muted);
    font-size: 0.88rem;
  }
  @media (max-width: 640px) {
    .top {
      grid-template-columns: 1fr 1fr;
    }
    .brand {
      grid-column: 1 / -1;
    }
  }
</style>
