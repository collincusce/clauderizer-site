---
// SCENE 07 — the invitation: three steps, then just drive.
const steps = [
  {
    n: '01',
    t: 'Clauderize any repo',
    c: 'uvx --from clauderizer clauderize init --size standard',
  },
  { n: '02', t: 'Point it at a goal', c: 'Plan a gameplan to ship the billing system' },
  { n: '03', t: 'Then, every session', c: 'Do the next phase' },
];
---

<section class="section quickstart" id="quickstart">
  <div class="container">
    <p class="slug reveal reveal-sm"><span class="no">Scene 07</span> The invitation</p>
    <h2 class="reveal">Three steps. <em>Then just drive.</em></h2>
    <p class="sub reveal">
      One command clauderizes any repository, in any language. You talk in plain English; your agent
      makes the tool calls and keeps your plan, graph, and memory in sync between sessions.
    </p>

    <ol class="steps">
      {
        steps.map((s) => (
          <li class="step reveal">
            <span class="idx" aria-hidden="true">
              {s.n}
            </span>
            <b>{s.t}</b>
            <button class="cmd" type="button" data-copy={s.c}>
              <code>{s.c}</code>
              <span class="copy-hint">copy</span>
            </button>
          </li>
        ))
      }
    </ol>

    <p class="install-line reveal">
      Prefer a real install? <code>pipx install "clauderizer[mcp]"</code>. The core engine has zero
      runtime dependencies.
    </p>
  </div>
</section>

<style>
  .quickstart {
    background: var(--ink-950);
  }
  .sub {
    margin: 0 0 2.4rem;
  }
  .steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.1rem;
  }
  .step {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.9rem;
    padding: 1.3rem;
    border: 1px solid var(--edge);
    border-radius: var(--radius);
    background: rgba(7, 9, 13, 0.5);
    transition:
      border-color 0.2s ease,
      transform 0.2s var(--ease-out-expo),
      box-shadow 0.2s ease;
  }
  .step:hover {
    border-color: var(--ember-line);
    transform: translateY(-3px);
    box-shadow: 0 24px 60px -34px var(--ember-glow);
  }
  .idx {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 2.5rem;
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1px var(--ember-line);
    transition:
      color 0.25s ease,
      -webkit-text-stroke-color 0.25s ease;
  }
  .step:hover .idx {
    color: var(--ember-400);
    -webkit-text-stroke-color: transparent;
    text-shadow: 0 0 26px var(--ember-glow);
  }
  .step b {
    font-size: 1.12rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .step .cmd {
    width: 100%;
    justify-content: space-between;
    gap: 0.7rem;
  }
  .step .cmd code {
    font-size: 0.8rem;
    overflow-wrap: anywhere;
  }
  .install-line {
    margin: 1.8rem 0 0;
    color: var(--cream-200);
    font-size: 1rem;
  }
  .install-line code {
    font-family: var(--font-mono);
    font-size: 0.88em;
    color: var(--ember-400);
    background: var(--ember-soft);
    padding: 0.14rem 0.4rem;
    border-radius: 5px;
  }
  @media (max-width: 900px) {
    .steps {
      grid-template-columns: 1fr;
    }
  }
</style>
