---
// SCENE 10 — questions, answered before you ask.
const faqs = [
  {
    q: 'What is Clauderizer?',
    a: 'Clauderizer gives AI coding agents durable, cross-session memory: plans, decisions, invariants, and a dependency graph stored as plain, Git-diffable Markdown the agent reads and updates through real tool calls.',
  },
  {
    q: 'How is it different from a CLAUDE.md or a rules file?',
    a: 'A rules file is prose the agent has to remember to read and follow. Clauderizer exposes memory as self-describing MCP tools and lifecycle hooks, so orientation and updates happen as executed tool calls, not conventions that quietly rot.',
  },
  {
    q: 'Where does the memory live?',
    a: 'In your repository, as Markdown under docs/. It ships with the code, shows up in diffs, and is reviewed alongside changes. The dependency graph is a disposable cache rebuilt from that Markdown; if they ever disagree, Markdown wins.',
    aHtml:
      'In your repository, as Markdown under <code>docs/</code>. It ships with the code, shows up in diffs, and is reviewed alongside changes. The dependency graph is a disposable cache rebuilt from that Markdown; if they ever disagree, Markdown wins.',
  },
  {
    q: 'Which AI coding tools does it work with?',
    a: 'One install wires every supported agent by default: Claude Code, Cursor, GitHub Copilot, OpenAI Codex, Gemini, Windsurf, Cline, Amp, Continue, Zed, Grok, and Kimi. Add --host to scope it to a single tool.',
  },
  {
    q: 'Is it free and open source?',
    a: 'Yes. Clauderizer is Apache 2.0 licensed with an explicit patent grant, and the core engine has zero runtime dependencies.',
  },
  {
    q: 'How do I get started?',
    a: 'Run uvx --from clauderizer clauderize init in any repository, or pipx install "clauderizer[mcp]" for a permanent install. Then point your agent at a goal and say "do the next phase" each session.',
    aHtml:
      'Run <code>uvx --from clauderizer clauderize init</code> in any repository, or <code>pipx install "clauderizer[mcp]"</code> for a permanent install. Then point your agent at a goal and say "do the next phase" each session.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<div class="faq" id="faq">
  <p class="slug reveal reveal-sm"><span class="no">Scene 09</span> Questions</p>
  <h2 class="reveal">Answers, <em>before you ask.</em></h2>

  <div class="faq-list">
    {
      faqs.map((f) => (
        <details class="faq-item reveal">
          <summary>
            <span class="q">{f.q}</span>
            <span class="chev" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="18" height="18">
                <path
                  d="M6 9l6 6 6-6"
                  stroke="currentColor"
                  stroke-width="2.2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  fill="none"
                />
              </svg>
            </span>
          </summary>
          <div class="faq-a">
            <p set:html={f.aHtml ?? f.a} />
          </div>
        </details>
      ))
    }
  </div>
</div>

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />

<style>
  .faq-list {
    margin-top: 1.8rem;
    display: flex;
    flex-direction: column;
    max-width: 54rem;
  }
  .faq-item {
    border-top: 1px solid var(--edge);
    transition: background 0.18s ease;
  }
  .faq-item:last-child {
    border-bottom: 1px solid var(--edge);
  }
  .faq-item[open] {
    background: rgba(245, 158, 11, 0.03);
  }
  summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.05rem 0.6rem;
    cursor: pointer;
    list-style: none;
    color: var(--cream-50);
    transition: color 0.16s ease;
  }
  summary::-webkit-details-marker {
    display: none;
  }
  summary::marker {
    content: '';
  }
  summary:hover {
    color: var(--ember-300);
  }
  summary:focus-visible {
    outline: 2px solid var(--ember-500);
    outline-offset: -2px;
    border-radius: 6px;
  }
  .q {
    font-family: var(--font-display);
    font-weight: 560;
    font-size: clamp(1.1rem, 1.9vw, 1.35rem);
    letter-spacing: -0.01em;
  }
  .chev {
    flex: none;
    color: var(--ember-400);
    transition: transform 0.25s var(--ease-out-expo);
  }
  .faq-item[open] .chev {
    transform: rotate(180deg);
  }
  .faq-a {
    padding: 0 0.6rem 1.4rem;
  }
  .faq-a p {
    margin: 0;
    color: var(--cream-200);
    max-width: 46rem;
    line-height: 1.66;
  }
  .faq-a code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    color: var(--ember-400);
    background: var(--ember-soft);
    padding: 0.1rem 0.35rem;
    border-radius: 5px;
    word-break: break-word;
  }
</style>
