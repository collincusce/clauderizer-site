---
// Same agent, same repo — the WITHOUT/WITH ledger, color-coded with semantic
// red ✗ / green ✓ icons and a closing line on each side (mirrors the README's
// amnesia-vs-memory asset, but with staggered scroll reveals).
const without = [
  'You re-explain the architecture. Again.',
  'A decision from an hour ago, contradicted.',
  '“Wait… did we already build this?”',
  'The plan drifts from reality, silently.',
];
const withCz = [
  'The digest greets the agent at session start.',
  'Decisions & invariants surface, not re-derived.',
  '“Phase 4 of 10, preflight passed, building.”',
  'The plan is the live state.',
];
---

<section class="section am" id="memory">
  <div class="container">
    <p class="kicker reveal reveal-sm">Same agent, same repo</p>
    <h2 class="reveal">One of them remembers.</h2>

    <div class="ledger">
      <article class="panel forget reveal">
        <header><span class="tag">Without Clauderizer</span></header>
        <ul>
          {
            without.map((t, i) => (
              <li style={`--d:${i}`}>
                <span class="mark bad" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="14" height="14">
                    <path
                      d="M7 7l10 10M17 7L7 17"
                      stroke="currentColor"
                      stroke-width="2.4"
                      stroke-linecap="round"
                      fill="none"
                    />
                  </svg>
                </span>
                <span>{t}</span>
              </li>
            ))
          }
        </ul>
        <p class="foot">every session starts from zero</p>
      </article>

      <div class="bridge reveal" aria-hidden="true">
        <span class="bridge-line"></span>
        <span class="bridge-arrow">→</span>
      </div>

      <article class="panel remember reveal">
        <header><span class="tag">With Clauderizer</span></header>
        <ul>
          {
            withCz.map((t, i) => (
              <li style={`--d:${i}`}>
                <span class="mark ok" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="14" height="14">
                    <path
                      d="M5 12.5l4.5 4.5L19 7.5"
                      stroke="currentColor"
                      stroke-width="2.4"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      fill="none"
                    />
                  </svg>
                </span>
                <span>{t}</span>
              </li>
            ))
          }
        </ul>
        <p class="foot ok-foot">every session is momentum →</p>
      </article>
    </div>
  </div>
</section>

<style>
  .am {
    background: var(--ink-900);
  }
  .ledger {
    margin-top: 2.6rem;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 1.4rem;
    align-items: stretch;
  }
  .panel {
    border-radius: var(--radius);
    border: 1px solid var(--edge);
    padding: 1.8rem;
    display: flex;
    flex-direction: column;
  }
  .panel header {
    margin-bottom: 1.1rem;
  }
  .panel .tag {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .panel ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.95rem;
    flex: 1;
  }
  .panel li {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.7rem;
    align-items: start;
    line-height: 1.45;
  }
  .mark {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    margin-top: 0.05rem;
  }
  .mark.bad {
    color: var(--bad);
    background: var(--bad-soft);
    border: 1px solid var(--bad-line);
  }
  .mark.ok {
    color: var(--ok);
    background: var(--ok-soft);
    border: 1px solid var(--ok-line);
  }
  .foot {
    margin: 1.4rem 0 0;
    font-size: 0.86rem;
    font-style: italic;
  }

  .forget {
    background: rgba(20, 22, 28, 0.55);
    filter: saturate(0.55);
  }
  .forget .tag {
    color: var(--muted);
  }
  .forget li span:last-child {
    color: var(--muted);
  }
  .forget .foot {
    color: var(--dim);
  }

  .remember {
    background:
      radial-gradient(130% 120% at 100% 0%, var(--ok-soft), transparent 58%),
      rgba(16, 20, 17, 0.7);
    border-color: var(--ok-line);
    box-shadow: 0 26px 64px -38px rgba(87, 194, 74, 0.4);
  }
  .remember .tag {
    color: var(--ok);
  }
  .remember li span:last-child {
    color: var(--cream-50);
  }
  .remember .ok-foot {
    color: var(--ok);
    font-weight: 600;
    font-style: normal;
    font-family: var(--font-mono);
    font-size: 0.82rem;
  }

  .bridge {
    display: grid;
    place-items: center;
    position: relative;
  }
  .bridge-arrow {
    font-size: 1.6rem;
    color: var(--clay);
  }
  .bridge-line {
    position: absolute;
    inset-inline: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--clay), transparent);
    opacity: 0.5;
  }

  /* staggered item reveal — content is fully visible by default (no-JS safe) */
  @media (prefers-reduced-motion: no-preference) {
    @supports (animation-timeline: view()) {
      .panel li {
        animation: am-item linear both;
        animation-timeline: view();
        animation-range: entry 6% entry 46%;
        animation-delay: calc(var(--d) * 0.04s);
      }
      @keyframes am-item {
        from {
          opacity: 0;
          transform: translateY(12px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
    }
  }

  @media (max-width: 760px) {
    .ledger {
      grid-template-columns: 1fr;
    }
    .bridge {
      height: 2.2rem;
    }
    .bridge-line {
      inset-block: 0;
      inset-inline: 50%;
      width: 1px;
      height: 100%;
      background: linear-gradient(180deg, transparent, var(--clay), transparent);
    }
    .bridge-arrow {
      transform: rotate(90deg);
    }
  }
</style>
